# GitHub and LLM settings (placeholders only)
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com

# 运行 llm_integration 测试前必须提供真实 LLM 环境变量
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=

# 显式开启 llm_integration 测试（默认 pytest 不会运行这类测试）
RUN_LLM_INTEGRATION=1

# Local paths
PLAYGROUND_REPOS_DIR=playground/repos
PLAYGROUND_OUTPUTS_DIR=playground/outputs
PLAYGROUND_LOGS_DIR=playground/logs
